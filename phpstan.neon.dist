parameters:
    level: max
    paths:
        - src

    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false

    ignoreErrors:
        # Laravel console command option types
        - '#Parameter .+ of method .+Command::.+ expects .+, array\|bool\|string(\|null)? given\.#'

        # Unused properties in testing utilities
        - '#Property .+ is never read, only written\.#'

        # Unused constants (kept for documentation)
        - '#Constant .+ is unused\.#'

        # Trait unused warning (traits are analyzed when used)
        - '#Trait .+ is used zero times and is not analysed\.#'

        # While true loops in continuous mode commands
        - '#While loop condition is always true\.#'

        # Generic Builder type specifications (complex Laravel internals)
        - '#PHPDoc tag @var for variable \$this contains generic class Illuminate\\Database\\Eloquent\\Builder#'

        # instanceof always true (from PHPDoc types)
        - '#Instanceof between .+ will always evaluate to true\.#'

        # method_exists always true (from PHPDoc types)
        - '#Call to function method_exists\(\) with .+ will always evaluate to true\.#'

        # Strict comparison always false (from PHPDoc types)
        - '#Strict comparison using === between array and false will always evaluate to false\.#'

        # Assert true always true (testing pattern)
        - '#Call to static method PHPUnit\\Framework\\Assert::assertTrue\(\) with true will always evaluate to true\.#'

        # Mixed types from Laravel app() helper
        - '#Cannot call method .+ on mixed\.#'
        - '#Cannot access property .+ on mixed\.#'
        - '#Property .+ does not accept mixed\.#'
        - '#Cannot cast mixed to .+\.#'
        - '#Binary operation .+ between mixed and .+ results in an error\.#'
        - '#Parameter .+ of function .+ expects .+, mixed given\.#'

        # ConnectionInterface vs Connection return types (Laravel internals)
        - '#Method .+ should return Illuminate\\Database\\Connection but returns Illuminate\\Database\\ConnectionInterface\.#'
        - '#Call to an undefined method Illuminate\\Database\\ConnectionInterface::.+\.#'

        # Generic parameter mismatches in cross-shard operations
        - '#Parameter .+ of method Illuminate\\Database\\Query\\Builder::get\(\) expects .+, array<int, mixed> given\.#'

        # Return type variations in shard query builders
        - '#Method .+ should return int<0, max> but returns int\.#'
        - '#Method .+ should return float\|int but returns mixed\.#'
        - '#Method .+ should return string\|null but returns mixed\.#'
        - '#Anonymous function should return .+ but returns .+\.#'

        # PHPDoc array type specifications in facades
        - '#Class .+ has PHPDoc tag @method for method .+ return type with no value type specified in iterable type array\.#'

        # pathinfo return type
        - '#Parameter .+ of function pathinfo expects string, mixed given\.#'
