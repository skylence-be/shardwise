{
    "name": "jonasvanderhaegen/sharded-db-package",
    "description": "Effortless database sharding for Laravel with zero configuration",
    "keywords": [
        "Skylence",
        "laravel",
        "sharded-db-package"
    ],
    "homepage": "https://github.com/jonasvanderhaegen/sharded-db-package",
    "license": "MIT",
    "authors": [
        {
            "name": "Jonas Vanderhaegen",
            "email": "jonasvanderh@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "ramsey/uuid": "^4.7",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "orchestra/testbench": "^10.4",
        "peckphp/peck": "^0.1.3",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-type-coverage": "^3.6",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Skylence\\Shardwise\\": "src/",
            "Skylence\\Shardwise\\Database\\Factories\\": "database/factories/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Skylence\\Shardwise\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": [
            "rector",
            "pint"
        ],
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:typos": "peck",
        "test:lint": [
            "pint --test"
        ],
        "test:unit": "pest --parallel --coverage --min=19",
        "test:types": "phpstan",
        "test": [
            "@test:lint",
            "@test:type-coverage",
            "@test:typos",
            "@test:unit",
            "@test:types"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Skylence\\Shardwise\\ShardwiseServiceProvider"
            ],
            "aliases": {
                "Shardwise": "Skylence\\Shardwise\\Facades\\Shardwise"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
